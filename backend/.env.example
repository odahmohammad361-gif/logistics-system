# Database — local PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/logistics_db

# JWT
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=Logistics System JO
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=yourpassword

# AWS Aurora (fill when moving to production)
# DATABASE_URL=postgresql+psycopg2://user:pass@your-cluster.rds.amazonaws.com:5432/logistics_db
